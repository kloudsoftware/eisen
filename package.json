{
    "name": "@kloudsoftware/eisen",
    "version": "3.0.4",
    "description": "Declarative and expressive TypeScript framework for building modern web applications",
    "main": "dist/index.cjs",
    "source": "src/index.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        },
        "./vite-plugin": {
            "types": "./dist/vite-plugin.d.ts",
            "import": "./dist/vite-plugin.mjs",
            "require": "./dist/vite-plugin.cjs"
        }
    },
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "npm run build && mocha",
        "example": "npm run build && tsc -p example/tsconfig.json && node scripts/serve-example.mjs"
    },
    "author": "Kloudsoftware",
    "license": "Apache-2.0",
    "types": "dist/index.d.ts",
    "devDependencies": {
        "jsdom": "^26.1.0",
        "lodash": "4.17.21",
        "mocha": "^11.7.1",
        "puppeteer-core": "^24.38.0",
        "tsup": "^8.1.0",
        "typescript": "^5.4.5"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/kloudsoftware/eisen"
    },
    "keywords": [
        "declarative",
        "expressive",
        "typescript"
    ],
    "sideEffects": false,
    "module": "dist/index.mjs",
    "files": [
        "dist"
    ]
}
